# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored. Never commit real ARNs or tokens.

# ---- Required: AWS Bedrock access ----
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# ---- Required: GitHub (fork/clone/push operations) ----
GITHUB_TOKEN=

# ---- Optional: OpenAI (only needed for the `gpt54` alias) ----
OPENAI_API_KEY=

# ---- Optional: Bedrock inference-profile ARNs ----
# Only fill in the ones you actually use. A missing ARN fails only if you
# invoke its alias (e.g. `--model glm5`). Format:
#   bedrock/converse/arn:aws:bedrock:<region>:<account>:application-inference-profile/<id>
BEDROCK_OPUS_ARN=
BEDROCK_KIMI_ARN=
BEDROCK_GLM5_ARN=
BEDROCK_MINIMAX_ARN=
BEDROCK_NOVA_PREMIER_ARN=
BEDROCK_NOVA2_LITE_ARN=
